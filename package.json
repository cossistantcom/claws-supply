{
  "name": "claws.supply",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --filter=@claws-supply/web",
    "build": "turbo build --filter=@claws-supply/web",
    "start": "turbo start --filter=@claws-supply/web",
    "lint": "turbo lint --filter=@claws-supply/web",
    "check:no-runtime-sql": "bun run --filter @claws-supply/web check:no-runtime-sql",
    "db:generate": "bun run --filter @claws-supply/web db:generate",
    "migrate": "bun run --filter @claws-supply/web migrate"
  },
  "devDependencies": {
    "turbo": "^2.8.12"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
